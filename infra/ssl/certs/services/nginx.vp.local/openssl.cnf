[req]
default_bits = 2048
prompt = no
default_md = sha256
distinguished_name = dn
req_extensions = v3_req

[dn]
C = RU
ST = Local
L = Dev
O = VideoPlatform
OU = Development
CN = nginx.vp.local

[v3_req]
basicConstraints = CA:FALSE
keyUsage = critical, digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth, clientAuth
subjectAltName = @alt_names

[alt_names]
DNS.1 = nginx.vp.local
DNS.2 = nginx
DNS.3 = localhost
IP.1 = 127.0.0.1
