@using WebApp.Common
@{
    ViewData["Title"] = "Загрузка видео";
}

<div class="container mt-4">
    <h1 class="mb-4">Загрузка видео</h1>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Выберите видеофайл для загрузки</h5>
                </div>
                <div class="card-body">
                    <form id="uploadForm" enctype="multipart/form-data">
                        <div class="form-group mb-3">
                            <label for="videoFile" class="form-label">Видеофайл</label>
                            <input type="file" class="form-control" id="videoFile" name="file" accept="video/*" required>
                            <div class="form-text">Поддерживаемые форматы: MP4, AVI, MOV, MKV и другие</div>
                        </div>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-upload"></i> Загрузить видео
                        </button>
                    </form>

                    <div id="progressContainer" class="mt-4" style="display: none;">
                        <h5>Прогресс:</h5>
                        <div class="progress" style="height: 30px;">
                            <div id="progressBar" class="progress-bar progress-bar-striped progress-bar-animated bg-success"
                                 role="progressbar" style="width: 0%">
                                0%
                            </div>
                        </div>
                        <div class="mt-2">
                            <span id="progressText" class="text-muted"></span>
                        </div>
                        <div id="statusText" class="mt-2 fw-bold"></div>
                    </div>

                    <div id="resultMessage" class="mt-3"></div>
                </div>
            </div>

            <div class="mt-3">
                <a href="@Url.Action("Index", "Lessons")" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Назад к урокам
                </a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card bg-light">
                <div class="card-body">
                    <h5 class="card-title">Информация</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <i class="bi bi-check-circle text-success"></i>
                            <strong>Чанковая загрузка:</strong> Видео разбивается на части по @ViewBag.ChunkSizeMB MB
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-check-circle text-success"></i>
                            <strong>Автоматическая обработка:</strong> После загрузки видео конвертируется в HLS
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-check-circle text-success"></i>
                            <strong>Прогресс в реальном времени:</strong> Отслеживайте статус обработки
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-check-circle text-success"></i>
                            <strong>Максимальный размер:</strong> @ViewBag.MaxFileSizeMB MB
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        window.AppConfig = {
            MaxFileSizeBytes: @AppConstants.MaxFileSizeBytes,
            MaxFileSizeMB: @AppConstants.MaxFileSizeMB,
            ChunkSizeBytes: @AppConstants.ChunkSizeBytes,
            ChunkSizeMB: @AppConstants.ChunkSizeMB
        };
    </script>
    <script src="~/js/video-upload.js"></script>
}