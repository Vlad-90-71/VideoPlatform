@model List<Shared.Models.VideoInfoDto>
@{
    ViewData["Title"] = "Список видео";
}

<div class="container mt-4">
    <h1 class="mb-4">Видеотека</h1>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> Видео пока нет. <a href="@Url.Action("Upload", "Videos")">Загрузить первое видео</a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var video in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">@video.FileName</h5>
                            <p class="card-text">
                                <small class="text-muted">
                                    <i class="bi bi-clock"></i> @video.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                                </small>
                            </p>
                            <p class="card-text">
                                <span class="badge @(video.Status == "Completed" ? "bg-success" : "bg-warning")">
                                    @video.Status
                                </span>
                            </p>
                        </div>
                        <div class="card-footer">
                            @if (video.Status == "Completed")
                            {
                                <a href="@Url.Action("Watch", "Videos", new { videoId = video.VideoId })" class="btn btn-primary">
                                    <i class="bi bi-play-circle"></i> Смотреть
                                </a>
                            }
                            else
                            {
                                <button class="btn btn-secondary" disabled>
                                    <i class="bi bi-hourglass-split"></i> Обработка...
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="mt-3">
        <a href="@Url.Action("Upload", "Videos")" class="btn btn-success">
            <i class="bi bi-upload"></i> Загрузить новое видео
        </a>
    </div>
</div>