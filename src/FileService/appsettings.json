{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Storage": {
    "Endpoint": "minio:9000",
    "PublicEndpoint": "webapp.vp.local", // ← ИЗМЕНИТЕ с minio.vp.local
    "AccessKey": "minio_admin",
    "SecretKey": "minio_secret",
    "Region": "us-east-1",
    "UseSSL": true,
    "VideoStorageBucket": "video-storage",
    "VideoHlsBucket": "video-hls",
    "PresignedUrlExpirySeconds": 3600
  },
  "RabbitMQ": {
    "Host": "rabbitmq",
    "Port": 5672,
    "Username": "vp_rabbit",
    "Password": "vp_rabbit_secret",
    "VirtualHost": "/"
  }
}
